# image-to-code-mcp — Environment Variables
#
# Just set model + API key. Provider auto-detected from model name.

# Model name (any vision-capable model)
IMAGE_EYES_MODEL=gpt-4o-mini

# Universal API key (auto-detects provider)
IMAGE_EYES_API_KEY=sk-your-key-here

# --- OR use provider-specific keys ---
# GEMINI_API_KEY=your-gemini-key   # For gemini-* models
# OPENAI_API_KEY=sk-your-key       # For gpt-* models
# ANTHROPIC_API_KEY=sk-ant-...     # For claude-* models
